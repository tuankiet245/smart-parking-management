{
  "name": "parking-management-system",
  "version": "1.0.0",
  "description": "AI-powered 2D Parking Management System with License Plate Recognition",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/server.js",
    "seed": "node server/scripts/seedData.js",
    "indexes": "node server/scripts/createIndexes.js",
    "backup": "server/scripts/backup.bat"
  },
  "keywords": [
    "parking",
    "AI",
    "license-plate-recognition",
    "ONNX",
    "React"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "simple-statistics": "^7.8.8",
    "socket.io": "^4.6.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}